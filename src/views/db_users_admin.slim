.users-admin-page
  - users_admin_config = { adminPath: admin_path, texts: { edit: t('user_admin.edit_user'), delete: t('user_admin.delete_user'), userFallback: 'user' } }
  sass:
    .users-admin-page
      max-width: 1120px
      margin: 0 auto
      padding: calc(var(--space-xl) * 2) var(--space-xl) var(--space-xl)
      color: var(--color-text)

    .users-admin-shell
      max-width: 860px
      margin: var(--space-xl) auto
      display: grid
      gap: var(--space-xl)

    .users-admin-messages
      position: fixed
      top: var(--space-xl)
      right: var(--space-xl)
      z-index: 400
      display: grid
      gap: var(--space-sm)
      width: calc(100vw - 2rem)
      max-width: 360px
      pointer-events: none

    .flash
      pointer-events: auto
      padding: var(--space-md) var(--space-lg)
      border-radius: var(--border-radius-sm)
      border: var(--border-width) solid transparent
      box-shadow: 0 12px 28px rgba(60, 64, 67, 0.18)

    .flash.notice
      background: #eaf6ed
      color: #137333
      border-color: rgba(19, 115, 51, 0.14)

    .flash.error
      background: #fce8e6
      color: #c5221f
      border-color: rgba(197, 34, 31, 0.14)

    .users-admin-panel
      background: var(--color-background-card)
      border: var(--border-width) solid var(--color-border)
      border-radius: var(--border-radius-md)
      box-shadow: var(--shadow-sm)
      overflow: hidden

    .users-admin-panel-header
      padding: var(--space-lg) var(--space-xl)
      border-bottom: var(--border-width) solid var(--color-border-light)

    .users-admin-panel-header h2
      font-size: var(--font-size-lg)
      font-weight: var(--font-weight-medium)
      margin-bottom: 0.2rem

    .users-admin-panel-subtitle
      color: var(--color-text-muted)
      font-size: var(--font-size-sm)

    .users-admin-panel-body
      padding: var(--space-xl)

    .users-admin-panel-footer
      padding: 0 var(--space-xl) var(--space-xl)

    .users-table
      width: 100%
      border-collapse: collapse
      table-layout: fixed

    .users-table th,
    .users-table td
      text-align: left
      padding: 0.9rem 1rem
      vertical-align: top

    .users-table th
      vertical-align: middle
      color: var(--color-text-muted)
      font-size: var(--font-size-xs)
      font-weight: var(--font-weight-medium)
      text-transform: uppercase
      letter-spacing: 0.06em
      white-space: nowrap
      line-height: 1.2

    .users-table th:nth-child(1),
    .users-table td:nth-child(1)
      width: 50%

    .users-table th:nth-child(2),
    .users-table td:nth-child(2)
      width: 20%

    .users-table th:nth-child(3),
    .users-table td:nth-child(3)
      width: 30%

    .users-table th:last-child,
    .users-table td:last-child
      text-align: right

    .users-table tbody td
      border-top: var(--border-width) solid var(--color-border-light)

    .users-table tbody tr:hover
      background: #fafcff

    .user-main
      display: grid
      gap: 0.2rem

    .user-login
      font-weight: var(--font-weight-medium)
      color: var(--color-text)

    .user-meta
      color: var(--color-text-muted)
      font-size: var(--font-size-sm)
      line-height: 1.4

    .role-text
      font-weight: var(--font-weight-medium)
      color: var(--color-text)

    .row-actions
      display: flex
      gap: var(--space-sm)
      flex-wrap: wrap
      justify-content: flex-end

    .users-table thead th:last-child
      padding-right: 1rem

    .users-table thead th:first-child
      padding-left: 1rem

    .users-admin-empty
      padding: var(--space-lg)
      color: var(--color-text-muted)
      text-align: center

    .form-grid
      display: grid
      gap: var(--space-md)

    .form-row
      display: grid
      gap: var(--space-xs)

    .form-split
      display: grid
      grid-template-columns: repeat(2, minmax(0, 1fr))
      gap: var(--space-md)

    .form-row label
      color: var(--color-text)
      font-weight: var(--font-weight-medium)

    .form-row input
      width: 100%
      padding: 0.8rem 0.85rem
      border: var(--border-width) solid var(--color-border)
      border-radius: var(--border-radius-sm)
      background: var(--color-background-card)
      color: var(--color-text)
      transition: border-color var(--transition-fast), box-shadow var(--transition-fast)

    .form-row input:focus
      outline: none
      border-color: rgba(26, 115, 232, 0.45)
      box-shadow: 0 0 0 3px rgba(26, 115, 232, 0.12)

    .button-row
      display: flex
      align-items: center
      align-content: center
      gap: var(--space-sm)
      flex-wrap: wrap
      margin-top: var(--space-sm)

    .modal-actions
      margin-top: var(--space-lg)
      display: flex
      align-items: center
      gap: var(--space-sm)
      flex-wrap: wrap

    .password-form
      display: block

    .password-form .form-row
      margin-bottom: var(--space-md)

    .password-form .modal-actions
      margin-top: 0

    .modal-actions .btn,
    .modal-actions form
      flex: 0 0 auto

    .button-row .btn,
    .button-row form
      flex: 0 0 auto

    .button-row form
      display: inline-flex

    .btn
      display: inline-flex
      align-items: center
      justify-content: center
      min-height: 36px
      padding: 0 0.9rem
      border-radius: 999px
      border: var(--border-width) solid var(--color-border)
      background: var(--color-background-card)
      color: var(--color-text)
      text-decoration: none
      cursor: pointer
      font-size: var(--font-size-sm)
      font-weight: var(--font-weight-medium)
      transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast)

    .btn:hover
      background: var(--color-hover-light)
      transform: translateY(-1px)

    .btn[disabled]
      opacity: 0.65
      cursor: default
      transform: none

    .btn-primary
      background: var(--color-primary)
      border-color: var(--color-primary)
      color: white

    .btn-primary:hover
      background: #1557b0
      border-color: #1557b0

    .btn-secondary
      background: #f7faff
      border-color: #d8e6fb
      color: #1a73e8

    .btn-secondary:hover
      background: #edf4ff

    .btn-danger
      background: #fff6f6
      border-color: #f1d2cf
      color: #c5221f

    .btn-ghost
      background: transparent
      border-color: transparent
      color: var(--color-text-muted)

    .btn-ghost:hover
      background: var(--color-hover-light)
      border-color: transparent

    .btn-icon::before
      display: inline-block
      margin-right: 0.4rem
      font-size: 24px
      line-height: 1

    .btn-icon-only
      width: 40px
      height: 40px
      min-width: 40px
      min-height: 40px
      padding: 0
      border-radius: 999px
      flex: 0 0 40px

    .btn-icon-only::before
      margin-right: 0
      font-size: 24px

    .btn-close
      width: 40px
      height: 40px
      min-width: 40px
      min-height: 40px
      padding: 0
      border-radius: 999px
      flex: 0 0 40px
      font-size: 0

    .btn-close::before
      content: '×'
      font-size: 24px
      line-height: 1
      margin-right: 0

    .btn-new::before
      content: '+'

    .btn-edit::before
      content: '✎'

    .btn-delete::before
      content: '×'

    .hint
      color: var(--color-text-muted)
      font-size: var(--font-size-sm)
      margin-top: var(--space-xs)

    .modal-copy
      color: var(--color-text-muted)
      line-height: 1.5

    .modal-copy + .modal-actions
      margin-top: var(--space-xl)

    .modal-overlay
      position: fixed
      inset: 0
      display: none
      align-items: center
      justify-content: center
      padding: var(--space-xl)
      background: rgba(32, 33, 36, 0.32)
      z-index: 300

    .modal-overlay.is-open
      display: flex

    .modal-card
      width: 100%
      max-width: 560px
      max-height: calc(100vh - 3rem)
      overflow: auto
      background: var(--color-background-card)
      border: var(--border-width) solid var(--color-border)
      border-radius: var(--border-radius-md)
      box-shadow: 0 16px 40px rgba(60,64,67,0.2)

    .modal-header
      display: flex
      justify-content: space-between
      align-items: flex-start
      gap: var(--space-md)
      padding: var(--space-xl)
      border-bottom: var(--border-width) solid var(--color-border-light)

    .modal-title h2
      font-size: var(--font-size-xl)
      font-weight: var(--font-weight-medium)
      margin-bottom: 0.2rem

    .modal-title p
      color: var(--color-text-muted)
      font-size: var(--font-size-sm)

    .modal-body
      padding: var(--space-xl)

    .modal-section + .modal-section
      margin-top: var(--space-xl)
      padding-top: var(--space-xl)
      border-top: var(--border-width) solid var(--color-border-light)

    @media (max-width: 900px)
      .form-split
        grid-template-columns: 1fr

      .users-table thead
        display: none

      .users-table,
      .users-table tbody,
      .users-table tr,
      .users-table td
        display: block

      .users-table tbody tr
        padding: var(--space-md) 0
        border-top: var(--border-width) solid var(--color-border-light)

      .users-table tbody td
        padding: 0 0 var(--space-sm)
        border-top: none

      .row-actions
        justify-content: flex-start

      .users-table
        table-layout: auto

    @media (max-width: 640px)
      .users-admin-page
        padding: calc(var(--space-md) * 2) var(--space-md) var(--space-md)

      .users-admin-messages
        top: var(--space-md)
        right: var(--space-md)
        width: calc(100vw - 2 * var(--space-md))

      .users-admin-panel-header,
      .users-admin-panel-body,
      .users-admin-panel-footer,
      .modal-header,
      .modal-body
        padding: var(--space-lg)

  .users-admin-shell
    .users-admin-messages#users-admin-messages

    .users-admin-panel
      .users-admin-panel-header
        h2 = t('user_admin.user_list')
        p.users-admin-panel-subtitle = t('user_admin.subtitle')
      .users-admin-panel-body
        table.users-table
          thead
            tr
              th = t('user_admin.fields.login')
              th = t('user_admin.fields.role')
              th = t('user_admin.actions')
          tbody#users-admin-table-body
            - users.each do |user|
              tr
                td
                  .user-main
                    .user-login = user[:login]
                    .user-meta = [user[:name], user[:email], user[:org]].reject { |value| value.to_s.empty? }.join(' · ')
                td
                  span.role-text = user[:role].to_s.empty? ? 'user' : user[:role]
                td
                  .row-actions
                    button.btn.btn-secondary.btn-icon.btn-icon-only.btn-edit type="button" data-login=user[:login] aria-label=t('user_admin.edit_user') title=t('user_admin.edit_user')
                    button.btn.btn-danger.btn-icon.btn-icon-only.btn-delete type="button" data-delete-login=user[:login] aria-label=t('user_admin.delete_user') title=t('user_admin.delete_user')
      .users-admin-panel-footer
        .button-row
          button.btn.btn-primary.btn-icon.btn-new type="button" data-open-modal="create-user-modal" = t('user_admin.new_user')

  #create-user-modal.modal-overlay data-modal="create-user-modal"
    .modal-card
      .modal-header
        .modal-title
          h2 = t('user_admin.create_user')
          p New user creation is kept in a separate dialog to avoid cluttering the list.
        button.btn.btn-ghost.btn-close type="button" data-close-modal="create-user-modal" aria-label=t('user_admin.cancel') title=t('user_admin.cancel')
      .modal-body
        form.form-grid#users-admin-create-form method="post" action=admin_path
          .form-row
            label for="modal-login" = t('user_admin.fields.login')
            input#modal-login type="text" name="login" required=true autocomplete="username"
          .form-row
            label for="modal-password" = t('user_admin.fields.password')
            input#modal-password type="password" name="password" required=true autocomplete="new-password"
          .form-row
            label for="modal-name" = t('user_admin.fields.name')
            input#modal-name type="text" name="name"
          .form-split
            .form-row
              label for="modal-role" = t('user_admin.fields.role')
              input#modal-role type="text" name="role"
            .form-row
              label for="modal-org" = t('user_admin.fields.org')
              input#modal-org type="text" name="org"
          .form-row
            label for="modal-email" = t('user_admin.fields.email')
            input#modal-email type="email" name="email"
        .modal-actions
          button.btn.btn-primary type="submit" form="users-admin-create-form" = t('user_admin.create_user')
          button.btn.btn-ghost type="button" data-close-modal="create-user-modal" = t('user_admin.cancel')

  #edit-user-modal.modal-overlay data-modal="edit-user-modal"
    .modal-card
      .modal-header
        .modal-title
          h2 = t('user_admin.edit_user')
          p#users-admin-edit-login
        button.btn.btn-ghost.btn-close type="button" data-close-modal="edit-user-modal" aria-label=t('user_admin.cancel') title=t('user_admin.cancel')
      .modal-body
        .modal-section
          form.form-grid#users-admin-edit-form method="post"
            .form-row
              label for="edit-login" = t('user_admin.fields.login')
              input#edit-login type="text" disabled=true
            .form-row
              label for="edit-name" = t('user_admin.fields.name')
              input#edit-name type="text" name="name"
            .form-split
              .form-row
                label for="edit-role" = t('user_admin.fields.role')
                input#edit-role type="text" name="role"
              .form-row
                label for="edit-org" = t('user_admin.fields.org')
                input#edit-org type="text" name="org"
            .form-row
              label for="edit-email" = t('user_admin.fields.email')
              input#edit-email type="email" name="email"
            .modal-actions
              button.btn.btn-primary type="submit" = t('user_admin.save')
              button.btn.btn-ghost type="button" data-close-modal="edit-user-modal" = t('user_admin.cancel')

        .modal-section
          form.password-form#users-admin-password-form method="post"
            .form-row
              label for="edit-password" = t('user_admin.fields.password')
              input#edit-password type="password" name="password" required=true autocomplete="new-password"
            .modal-actions
              button.btn.btn-secondary type="submit" = t('user_admin.change_password')

  #delete-user-modal.modal-overlay data-modal="delete-user-modal"
    .modal-card
      .modal-header
        .modal-title
          h2 = t('user_admin.delete_user')
          p#users-admin-delete-login
        button.btn.btn-ghost.btn-close type="button" data-close-modal="delete-user-modal" aria-label=t('user_admin.cancel') title=t('user_admin.cancel')
      .modal-body
        p.modal-copy = t('user_admin.delete_confirmation')
        .modal-actions
          form#users-admin-delete-form method="post"
            button.btn.btn-danger type="submit" = t('user_admin.delete_user')
          button.btn.btn-ghost type="button" data-close-modal="delete-user-modal" = t('user_admin.cancel')

  script id="users-admin-data" type="application/json" == JSON.generate(users)
  script id="users-admin-config" type="application/json" == JSON.generate(users_admin_config)
  script type="text/javascript"
    |
      (() => {
        const config = JSON.parse(document.getElementById('users-admin-config').textContent || '{}');
        const adminPath = config.adminPath || '';
        const messagesEl = document.getElementById('users-admin-messages');
        const tableBodyEl = document.getElementById('users-admin-table-body');
        const initialUsers = JSON.parse(document.getElementById('users-admin-data').textContent || '[]');
        const modals = document.querySelectorAll('[data-modal]');
        const createForm = document.getElementById('users-admin-create-form');
        const editForm = document.getElementById('users-admin-edit-form');
        const passwordForm = document.getElementById('users-admin-password-form');
        const deleteForm = document.getElementById('users-admin-delete-form');
        const editLoginTitleEl = document.getElementById('users-admin-edit-login');
        const editLoginInputEl = document.getElementById('edit-login');
        const deleteLoginTitleEl = document.getElementById('users-admin-delete-login');
        const texts = config.texts || {edit: 'Edit', delete: 'Delete', userFallback: 'user'};

        const state = {users: initialUsers};

        function escapeHtml(value) {
          return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
        }

        function userMeta(user) {
          return [user.name, user.email, user.org].filter(Boolean).join(' · ');
        }

        function roleText(user) {
          return user.role && user.role.length > 0 ? user.role : texts.userFallback;
        }

        function rowMarkup(user) {
          return `
            <tr>
              <td>
                <div class="user-main">
                  <div class="user-login">${escapeHtml(user.login)}</div>
                  <div class="user-meta">${escapeHtml(userMeta(user))}</div>
                </div>
              </td>
              <td><span class="role-text">${escapeHtml(roleText(user))}</span></td>
              <td>
                <div class="row-actions">
                  <button class="btn btn-secondary btn-icon btn-icon-only btn-edit" type="button" data-login="${escapeHtml(user.login)}" aria-label="${escapeHtml(texts.edit)}" title="${escapeHtml(texts.edit)}"></button>
                  <button class="btn btn-danger btn-icon btn-icon-only btn-delete" type="button" data-delete-login="${escapeHtml(user.login)}" aria-label="${escapeHtml(texts.delete)}" title="${escapeHtml(texts.delete)}"></button>
                </div>
              </td>
            </tr>
          `;
        }

        function renderTable() {
          if (!state.users.length) {
            tableBodyEl.innerHTML = `<tr><td colspan="3"><div class="users-admin-empty">No users</div></td></tr>`;
            return;
          }
          tableBodyEl.innerHTML = state.users.map(rowMarkup).join('');
        }

        function setFlash(type, message) {
          if (!message) return;
          messagesEl.innerHTML = `<div class="flash ${escapeHtml(type)}">${escapeHtml(message)}</div>`;
        }

        function clearFlash() {
          messagesEl.innerHTML = '';
        }

        function openModal(name) {
          const modal = document.querySelector(`[data-modal="${name}"]`);
          if (modal) modal.classList.add('is-open');
        }

        function resetModal(name) {
          if (name === 'create-user-modal') {
            createForm.reset();
          }

          if (name === 'edit-user-modal') {
            editForm.reset();
            passwordForm.reset();
            editLoginTitleEl.textContent = '';
            editLoginInputEl.value = '';
            editForm.action = '';
            passwordForm.action = '';
          }

          if (name === 'delete-user-modal') {
            deleteForm.reset();
            deleteLoginTitleEl.textContent = '';
            deleteForm.action = '';
          }
        }

        function closeModal(name) {
          const modal = document.querySelector(`[data-modal="${name}"]`);
          if (!modal) return;

          modal.classList.remove('is-open');
          resetModal(name);
        }

        function closeAllModals() {
          modals.forEach((modal) => closeModal(modal.getAttribute('data-modal')));
        }

        function findUser(login) {
          return state.users.find((user) => user.login === login);
        }

        function openEditModal(login) {
          const user = findUser(login);
          if (!user) return;

          editLoginTitleEl.textContent = user.login;
          editLoginInputEl.value = user.login;
          document.getElementById('edit-name').value = user.name || '';
          document.getElementById('edit-role').value = user.role || '';
          document.getElementById('edit-org').value = user.org || '';
          document.getElementById('edit-email').value = user.email || '';
          document.getElementById('edit-password').value = '';
          editForm.action = `${adminPath}/${encodeURIComponent(user.login)}`;
          passwordForm.action = `${adminPath}/${encodeURIComponent(user.login)}/password`;
          openModal('edit-user-modal');
        }

        function openDeleteModal(login) {
          const user = findUser(login);
          if (!user) return;

          deleteLoginTitleEl.textContent = user.login;
          deleteForm.action = `${adminPath}/${encodeURIComponent(user.login)}/delete`;
          openModal('delete-user-modal');
        }

        async function request(form) {
          const response = await fetch(form.action, {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'X-Requested-With': 'XMLHttpRequest'
            },
            body: new FormData(form)
          });

          let payload = {};
          try {
            payload = await response.json();
          } catch (_error) {
            payload = {};
          }

          if (!response.ok) {
            throw new Error(payload.error || `Request failed: ${response.status}`);
          }

          return payload;
        }

        function submitButtonFor(form) {
          return form.querySelector('button[type="submit"]') || document.querySelector(`button[type="submit"][form="${form.id}"]`);
        }

        function withPending(button, action) {
          if (!button) {
            return Promise.resolve(action());
          }
          const originalDisabled = button.disabled;
          button.disabled = true;
          return Promise.resolve(action()).finally(() => {
            button.disabled = originalDisabled;
          });
        }

        createForm.addEventListener('submit', (event) => {
          event.preventDefault();
          const submitButton = submitButtonFor(createForm);
          withPending(submitButton, async () => {
            const payload = await request(createForm);
            state.users = payload.users || state.users;
            renderTable();
            closeModal('create-user-modal');
            setFlash('notice', payload.notice);
          }).catch((error) => setFlash('error', error.message));
        });

        editForm.addEventListener('submit', (event) => {
          event.preventDefault();
          const submitButton = submitButtonFor(editForm);
          withPending(submitButton, async () => {
            const payload = await request(editForm);
            state.users = payload.users || state.users;
            renderTable();
            closeModal('edit-user-modal');
            setFlash('notice', payload.notice);
          }).catch((error) => setFlash('error', error.message));
        });

        passwordForm.addEventListener('submit', (event) => {
          event.preventDefault();
          const submitButton = submitButtonFor(passwordForm);
          withPending(submitButton, async () => {
            const payload = await request(passwordForm);
            state.users = payload.users || state.users;
            document.getElementById('edit-password').value = '';
            closeModal('edit-user-modal');
            setFlash('notice', payload.notice);
          }).catch((error) => setFlash('error', error.message));
        });

        deleteForm.addEventListener('submit', (event) => {
          event.preventDefault();
          const submitButton = submitButtonFor(deleteForm);
          withPending(submitButton, async () => {
            const payload = await request(deleteForm);
            state.users = payload.users || state.users;
            renderTable();
            closeModal('delete-user-modal');
            setFlash('notice', payload.notice);
          }).catch((error) => setFlash('error', error.message));
        });

        document.addEventListener('click', (event) => {
          const openButton = event.target.closest('[data-open-modal]');
          if (openButton) {
            clearFlash();
            openModal(openButton.getAttribute('data-open-modal'));
            return;
          }

          const closeButton = event.target.closest('[data-close-modal]');
          if (closeButton) {
            closeModal(closeButton.getAttribute('data-close-modal'));
            return;
          }

          const editButton = event.target.closest('[data-login]');
          if (editButton) {
            clearFlash();
            openEditModal(editButton.getAttribute('data-login'));
            return;
          }

          const deleteButton = event.target.closest('[data-delete-login]');
          if (deleteButton) {
            clearFlash();
            openDeleteModal(deleteButton.getAttribute('data-delete-login'));
            return;
          }

          const overlay = event.target.closest('.modal-overlay');
          if (overlay && event.target === overlay) {
            closeModal(overlay.getAttribute('data-modal'));
          }
        });

        renderTable();
      })();
